<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config. Allows cleartext HTTP to the Firebase
  Local Emulator Suite. Production builds use cleartextTrafficPermitted=false
  by default; this file lives under src/debug/ so it never ships to release.

  10.0.2.2  → host machine's localhost from the Android emulator
  127.0.0.1 → loopback (rare, but covers `adb reverse` setups)
  localhost → physical-device-via-USB scenarios that proxy back to host
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
